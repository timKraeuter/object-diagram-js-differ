{
  "name": "object-diagram-js-differ",
  "version": "2.0.0",
  "description": "A semantic diffing utility for object diagram files",
  "scripts": {
    "all": "run-s lint test build",
    "lint": "eslint .",
    "lintFix": "eslint . --fix",
    "test": "jasmine",
    "build": "rollup -c --bundleConfigAsCjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timKraeuter/object-diagram-js-differ.git"
  },
  "main": "./dist/index.cjs",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.esm.js",
      "node": "./dist/index.cjs"
    }
  },
  "keywords": [
    "object diagram",
    "diff"
  ],
  "author": {
    "name": "Tim Kräuter",
    "url": "https://timkraeuter.com/"
  },
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "eslint-plugin-bpmn-io": "^2.2.0",
    "jasmine": "^6.0.0",
    "npm-run-all": "^4.1.5",
    "object-diagram-moddle": "^1.0.3",
    "rollup": "^4.57.1"
  },
  "dependencies": {
    "diffpatch": "^0.6.0",
    "min-dash": "^5.0.0"
  },
  "files": [
    "dist"
  ]
}
